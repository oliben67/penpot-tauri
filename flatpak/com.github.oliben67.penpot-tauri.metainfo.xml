<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
    <id>com.github.oliben67.penpot-tauri</id>
    <launchable type="desktop-id">com.github.oliben67.penpot-tauri.desktop</launchable>
    <name>Penpot</name>
    <summary>Open-source prototyping and design platform</summary>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>

    <description>
        <p>Penpot is the first open-source design and prototyping platform meant for cross-domain teams. It works with open web standards (SVG) and is a great alternative to Figma.</p>
        <p>This is a Tauri wrapper that connects to a local self-hosted Penpot instance.</p>
        <p>Features:</p>
        <ul>
            <li>Supports unlimited projects</li>
            <li>Large artboard selection: mobile, web, tablet, social media posters, and custom</li>
            <li>Unlimited users with roles and different permissions</li>
            <li>Layer support</li>
            <li>Open-source</li>
            <li>Real-time collaboration between team members</li>
            <li>Export artboards to PDF</li>
            <li>Comments tool and Comment viewer</li>
            <li>Shared libraries among teams</li>
            <li>Download the source image with SVG and CSS support</li>
        </ul>
    </description>

    <url type="homepage">https://penpot.app</url>
    <url type="help">https://help.penpot.app/</url>
    <url type="bugtracker">https://github.com/oliben67/penpot-tauri/issues</url>
    <url type="vcs-browser">https://github.com/oliben67/penpot-tauri</url>

    <screenshots>
