{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui-tauri/refs/heads/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "Penpot",
  "version": "1.0.0",
  "identifier": "com.github.oliben67.penpot",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Penpot",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* https://*; frame-src http://localhost:* https://*; img-src 'self' data: http://localhost:* https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
